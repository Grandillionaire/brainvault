# Frontend Development Server
VITE_API_URL=http://localhost:3001/api
VITE_WS_URL=ws://localhost:3001/ws

# Backend Server
PORT=3001
DB_PATH=./data/brainvault.db
VAULT_PATH=./data/vault
ATTACHMENTS_PATH=./data/attachments

# AI/Ollama Configuration (optional)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:1420,http://localhost:5173

# JWT Secret (for multi-user setup)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_OF_AT_LEAST_32_CHARACTERS

# Environment
NODE_ENV=development
